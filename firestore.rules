rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // -------------------------------------------------------------------------
    // GLOBALS & HELPERS
    // -------------------------------------------------------------------------
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      // Bootstrapped admin check + database check
      return isSignedIn() && (
        request.auth.token.email == 'abdulmoiz1914@gmail.com' ||
        request.auth.token.email == 'i230722@isb.nu.edu.pk' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // -------------------------------------------------------------------------
    // CATCH-ALL DENY
    // -------------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // -------------------------------------------------------------------------
    // USERS COLLECTION
    // -------------------------------------------------------------------------
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['uid', 'name', 'email', 'role', 'createdAt']) &&
               data.keys().size() == 5 &&
               data.uid is string && data.uid.size() <= 128 &&
               data.name is string && data.name.size() <= 100 &&
               data.email is string && data.email.size() <= 100 &&
               data.role in ['admin', 'user'] &&
               data.createdAt is timestamp;
      }

      // Users can read and write their own profile during creation.
      // Admins can read all profiles.
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().role == 'user';
      
      allow update: if isAdmin() || (
        isOwner(userId) && 
        isValidUser(incoming()) && 
        incoming().role == existing().role && // Users cannot change their own role
        incoming().uid == existing().uid &&
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'email'])
      );

      allow delete: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // BOOKINGS COLLECTION
    // -------------------------------------------------------------------------
    match /bookings/{bookingId} {
      function isValidBooking(data) {
        return data.keys().hasAll(['bookingId', 'userId', 'guestName', 'email', 'phone', 'roomType', 'guests', 'checkIn', 'checkOut', 'status', 'createdAt']) &&
               data.bookingId is string &&
               data.userId == request.auth.uid &&
               data.guestName is string && data.guestName.size() <= 100 &&
               data.email is string &&
               data.phone is string &&
               data.guests is number && data.guests >= 1 &&
               data.status in ['pending', 'accepted', 'rejected'] &&
               data.createdAt is timestamp;
      }

      // Users can read their own bookings. Admins can read all.
      allow list: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow get: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);

      allow create: if isSignedIn() && isValidBooking(incoming()) && incoming().status == 'pending';
      
      allow update: if isAdmin() && (
        // Admin action: Change status
        incoming().diff(existing()).affectedKeys().hasOnly(['status'])
      );

      allow delete: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // ROOMS COLLECTION
    // -------------------------------------------------------------------------
    match /rooms/{roomId} {
      allow read: if true; // Publicly available for browsing
      allow write: if isAdmin();
    }
  }
}
